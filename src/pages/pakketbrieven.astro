---

<Layout title="Pakketbrieven" description="Wekelijkse pakketbrieven van 't Leeuweriksveld met recepten en tips voor uw groenteabonnement — archief 2024 t/m heden.">
  <div class="pagina-hero">
    <h1>Pakketbrieven</h1>
    <p>Wekelijkse brieven met recepten en bereidingstips — archief 2024 t/m nu</p>
  </div>

  <div class="broodkruimel">
    <div class="container">
      <a href={`${b}/`}>Home</a> &rsaquo; <a href={`${b}/nieuws/`}>Nieuws</a> &rsaquo; Pakketbrieven
    </div>
  </div>

  <section class="sectie">
    <div class="container-smal">

      <div class="info-banner">
        <p>Bij elk groenteabonnement ontvangt u wekelijks een pakketbrief met recepten en bereidingstips voor de groenten van die week. Hieronder vindt u het archief van 2024 tot nu.</p>
      </div>

      <!-- Jaarnavigatie -->
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
        {jaren.map(jaar => (
          <a href={`#jaar-${jaar}`} class="knop knop-omlijnd" style="padding: 0.4rem 1rem;">{jaar}</a>
        ))}
      </div>

      {jaren.map(jaar => (
        <div id={`jaar-${jaar}`} style="margin-bottom: 3rem;">
          <h2 style="border-bottom: 2px solid var(--groen-zacht); padding-bottom: 0.5rem; margin-bottom: 1.25rem;">{jaar}</h2>
          <div class="pakket-grid">
            {brieven[jaar].map(b => (
              <a
                href={`${basis}${b.bestand}`}
                target="_blank"
                rel="noopener"
                class="pakket-item"
              >
                <span class="pakket-week">Week {b.week}</span>
                <span class="pakket-type">{b.bestand.endsWith('.pdf') ? 'PDF' : 'HTML'}</span>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>
</Layout>

<style>
  .pakket-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.5rem;
  }

  .pakket-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.6rem 0.5rem;
    border: 1px solid var(--groen-zacht);
    border-radius: 6px;
    text-decoration: none;
    color: var(--tekst);
    background: white;
    transition: background 0.15s, border-color 0.15s;
  }

  .pakket-item:hover {
    background: var(--groen-zacht);
    border-color: var(--groen);
  }

  .pakket-week {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .pakket-type {
    font-size: 0.7rem;
    color: var(--tekst-zacht);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
