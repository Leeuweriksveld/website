---
import Layout from '../layouts/Layout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Afhaalpunten" description="Overzicht van alle afhaalpunten in Drenthe voor groenteabonnementen van 't Leeuweriksveld.">
 <div class="pagina-hero">
 <h1>Afhaalpunten</h1>
 <p>Op meer dan 40 locaties in Drenthe klaarstaan op woensdag of donderdag</p>
 </div>

 <div class="broodkruimel">
 <div class="container">
 <a href={`${b}/`}>Home</a> › Afhaalpunten
 </div>
 </div>

