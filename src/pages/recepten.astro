---
import Layout from '../layouts/Layout.astro';
import pakketbrieven from '../data/pakketbrieven.json';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const basis = 'https://www.leeuweriksveld.nl/';

// Bouw een index: groente → lijst van { recept, week, jaar, bestand }
const receptenPerGroente: Record<string, { titel: string; week: number | string; jaar: number; bestand: string }[]> = {};

for (const brief of pakketbrieven) {
  for (const recept of brief.recepten) {
    // Koppel het recept aan elke groente in deze brief
    for (const groente of brief.groenten) {
      if (!receptenPerGroente[groente]) receptenPerGroente[groente] = [];
      // Voeg toe als dit recept nog niet voor deze groente bestaat
      const bestaat = receptenPerGroente[groente].some(r => r.titel === recept && r.week === brief.week && r.jaar === brief.jaar);
      if (!bestaat) {
        receptenPerGroente[groente].push({ titel: recept, week: brief.week, jaar: brief.jaar, bestand: brief.bestand });
      }
    }
  }
}

// Sorteer groenten alfabetisch
const groenten = Object.keys(receptenPerGroente).sort((a, b) => a.localeCompare(b, 'nl'));

// Unieke beginletters
const letters = [...new Set(groenten.map(g => g[0].toUpperCase()))];
---

<Layout title="Recepten" description="Recepten van 't Leeuweriksveld per groente — rechtstreeks uit de wekelijkse pakketbrieven.">
  <div class="pagina-hero">
    <h1>Recepten</h1>
    <p>Per groente — uit onze wekelijkse pakketbrieven</p>
  </div>

  <div class="broodkruimel">
    <div class="container">
      <a href={`${b}/`}>Home</a> &rsaquo; Recepten
    </div>
  </div>

  <section class="sectie">
    <div class="container">

      <div class="info-banner" style="margin-bottom: 2rem;">
        <p>Deze pagina wordt automatisch gevuld vanuit de wekelijkse pakketbrieven. Bij elk recept staat in welke week het verscheen — klik om de volledige pakketbrief te lezen. Archief loopt van begin 2024 tot nu.</p>
      </div>

      <!-- Letternavigatie -->
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
        {letters.map(letter => (
          <a href={`#letter-${letter}`} class="knop knop-omlijnd" style="padding: 0.35rem 0.75rem; font-size: 0.9rem;">{letter}</a>
        ))}
        <a href={`${b}/pakketbrieven/`} class="knop knop-groen" style="padding: 0.35rem 0.75rem; font-size: 0.9rem; margin-left: auto;">Alle pakketbrieven →</a>
      </div>

      <!-- Recepten per groente -->
      {letters.map(letter => (
        <div id={`letter-${letter}`} style="margin-bottom: 2.5rem;">
          <h2 class="recept-letter-kop">{letter}</h2>
          <div class="recept-index">
            {groenten.filter(g => g[0].toUpperCase() === letter).map(groente => (
              <div class="recept-groente">
                <h3>{groente}</h3>
                <ul class="recept-lijst">
                  {receptenPerGroente[groente].map(r => (
                    <li>
                      <a href={`${basis}${r.bestand}`} target="_blank" rel="noopener" class="recept-link">
                        {r.titel}
                      </a>
                      <span class="recept-bron">week {r.week}, {r.jaar}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>
</Layout>

<style>
  .recept-lijst {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
  }

  .recept-lijst li {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--groen-zacht);
    flex-wrap: wrap;
  }

  .recept-link {
    color: var(--tekst);
    text-decoration: none;
    flex: 1;
    min-width: 180px;
  }

  .recept-link:hover {
    color: var(--groen);
    text-decoration: underline;
  }

  .recept-bron {
    font-size: 0.75rem;
    color: var(--tekst-zacht);
    white-space: nowrap;
  }
</style>
