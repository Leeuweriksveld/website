const letters = [...new Set(groenten.map(g => g.letter))];
---

<Layout title="Recepten" description="Recepten van A tot Z voor groenten van 't Leeuweriksveld, met bereidingstips en bewaartips.">
 <div class="pagina-hero">
 <h1>Recepten</h1>
 <p>Meer dan 300 recepten voor seizoensgroenten &mdash; van aardappel tot zuurkool</p>
 </div>

 <div class="broodkruimel">
 <div class="container">
 <a href="/">Home</a> &rsaquo; Recepten
 </div>
 </div>

 <section class="sectie">
 <div class="container">

 <div class="info-banner">
 <p><strong>Wekelijkse pakketbrief:</strong> Bij elk groenteabonnement ontvangt u een pakketbrief met recepten en bereidingstips, specifiek voor de groenten van die week. Al deze recepten zijn ook terug te vinden in onderstaand overzicht.</p>
 </div>

 <!-- Letternavigatie -->
 <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
 {letters.map(letter => (
 <a href={`#letter-${letter}`} class="knop knop-omlijnd" style="padding: 0.35rem 0.75rem; font-size: 0.9rem;">{letter}</a>
 ))}
 </div>

 <!-- Groenten per letter -->
 {letters.map(letter => (
 <div id={`letter-${letter}`}>
 <h2 class="recept-letter-kop">{letter}</h2>
 <div class="recept-index">
 {groenten.filter(g => g.letter === letter).map(g => (
 <div class="recept-groente">
 <h3>{g.naam}</h3>
 <p class="recept-info">{g.tips}</p>
 <span class="recept-aantal">{g.aantal} recepten</span>
 </div>
 ))}
 </div>
 </div>
 ))}

 <div class="inhoud-blok" style="margin-top: 3rem;">
 <h2>Recepten per pakketbrief</h2>
 <p>Alle recepten op deze pagina zijn afkomstig uit onze wekelijkse pakketbrieven, die we meegeven bij het groenteabonnement. Het archief loopt van 2009 tot heden. Heeft u een specifiek recept nodig dat u niet kunt vinden? Neem gerust contact met ons op.</p>
 <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.25rem;">
 <a href="tel:0591381445" class="knop knop-groen">0591-381445</a>
 <a href="mailto:info@leeuweriksveld.nl" class="knop knop-primair">info@leeuweriksveld.nl</a>
 </div>
 </div>

 </div>
 </section>
</Layout>
