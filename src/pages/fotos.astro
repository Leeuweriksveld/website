---
import Layout from '../layouts/Layout.astro';
const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const galerijen = [
  {
    jaar: "2021",
    label: "Open dag 2021",
    fotos: [
      { src: "/afb/lw-zehra-met-net-geoogste-lichtwortel.jpg", alt: "Open dag 2021 — oogst lichtwortel" },
      { src: "/afb/appelsapdag-2021.jpg", alt: "Appelsapdag 2021" },
    ]
  },
  {
    jaar: "2017",
    label: "Oogstfeest 2017",
    fotos: [
      { src: "/afb/oogstfeest-2017.png", alt: "Oogstfeest 2017" },
    ]
  },
  {
    jaar: "2016",
    label: "Open dag 2016",
    fotos: [
      { src: "/afb/opendag-2016.jpg", alt: "Open dag 2016" },
    ]
  },
  {
    jaar: "2014",
    label: "Open dag 2014",
    fotos: [
      { src: "/afb/opendag-2014.jpg", alt: "Open dag 2014" },
    ]
  },
  {
    jaar: "2013",
    label: "Open dag 2013",
    fotos: [
      { src: "/afb/opendag-2013.jpg", alt: "Open dag 2013 — aardbeien" },
    ]
  },
  {
    jaar: "2012",
    label: "Open dag 2012",
    fotos: [
      { src: "/afb/opendag-2012.jpg", alt: "Open dag 2012" },
    ]
  },
  {
    jaar: "2011",
    label: "Open dag 2011",
    fotos: [
      { src: "/afb/opendag-2011.jpg", alt: "Open dag 2011" },
      { src: "/afb/nieuw-dak.jpg", alt: "Nieuw dak op de schuur" },
    ]
  },
  {
    jaar: "2010",
    label: "Open dag 2010",
    fotos: [
      { src: "/afb/opendag-2010.jpg", alt: "Open dag 2010" },
    ]
  },
];
---

<Layout title="Foto's" description="Fotogalerij van 't Leeuweriksveld — open dagen, oogstfeesten en het dagelijkse leven op de boerderij.">
  <div class="pagina-hero">
    <h1>Foto's</h1>
    <p>Open dagen, oogstfeesten en het leven op 't Leeuweriksveld</p>
  </div>

  <div class="broodkruimel">
    <div class="container">
      <a href={`${b}/`}>Home</a> &rsaquo; Foto's
    </div>
  </div>

  <section class="sectie">
    <div class="container">

      <h2 style="margin-bottom: 1.5rem;">Van het bedrijf</h2>
      <div class="foto-grid">
        <div class="foto-item">
          <img src={`${b}/afb/lw-floriaan-met-net-geoogste-lichtwortel.jpg`} alt="Oogst van lichtwortel" />
          <span>Oogst van lichtwortel</span>
        </div>
        <div class="foto-item">
          <img src={`${b}/afb/lw-blootgelegde-lichtwortels.jpg`} alt="Lichtwortel in de grond" />
          <span>Lichtwortel in de grond</span>
        </div>
        <div class="foto-item">
          <img src={`${b}/afb/lw-zehra-met-net-geoogste-lichtwortel.jpg`} alt="Verse lichtwortel geoogst" />
          <span>Verse lichtwortel geoogst</span>
        </div>
        <div class="foto-item">
          <img src={`${b}/afb/lw-lichtwortel-schoon.jpg`} alt="Lichtwortel klaar voor levering" />
          <span>Klaar voor levering</span>
        </div>
        <div class="foto-item">
          <img src={`${b}/afb/leeuweriksveld_veld.png`} alt="Overzicht van het veld" />
          <span>Het veld</span>
        </div>
        <div class="foto-item">
          <img src={`${b}/afb/kerkuil.jpg`} alt="Kerkuil bij 't Leeuweriksveld" />
          <span>Kerkuil op de boerderij</span>
        </div>
        <div class="foto-item">
          <img src={`${b}/afb/kathinka-en-wouter.jpg`} alt="Kathinka en Wouter" />
          <span>Kathinka en Wouter</span>
        </div>
        <div class="foto-item">
          <img src={`${b}/afb/kippenkar.png`} alt="De kippenkar" />
          <span>De kippenkar</span>
        </div>
      </div>

      {galerijen.map(galerie => (
        <div style="margin-top: 3rem;">
          <h2 style="margin-bottom: 1.25rem; border-bottom: 2px solid var(--groen-zacht); padding-bottom: 0.5rem;">
            {galerie.label}
          </h2>
          <div class="foto-grid">
            {galerie.fotos.map(foto => (
              <div class="foto-item">
                <img src={`${b}${foto.src}`} alt={foto.alt} />
                <span>{foto.alt}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>
</Layout>

<style>
  .foto-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }

  .foto-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .foto-item img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .foto-item span {
    font-size: 0.8rem;
    color: var(--tekst-zacht);
    text-align: center;
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .foto-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
