---
import Layout from '../layouts/Layout.astro';

const galerijen = [
  {
    jaar: "2021",
    fotos: [
      { src: "/afb/lw-zehra-met-net-geoogste-lichtwortel.jpg", alt: "Open dag 2021" },
      { src: "/afb/appelsapdag-2021.jpg", alt: "Appelsapdag 2021" },
    ]
  },
  {
    jaar: "2017",
    fotos: [
      { src: "/afb/oogstfeest-2017.png", alt: "Oogstfeest 2017" },
    ]
  },
  {
    jaar: "2016",
    fotos: [
      { src: "/afb/opendag-2016.jpg", alt: "Open dag 2016" },
    ]
  },
  {
    jaar: "2014",
    fotos: [
      { src: "/afb/opendag-2014.jpg", alt: "Open dag 2014" },
    ]
  },
  {
    jaar: "2013",
    fotos: [
      { src: "/afb/opendag-2013.jpg", alt: "Open dag 2013 — aardbeien" },
    ]
  },
  {
    jaar: "2012",
    fotos: [
      { src: "/afb/opendag-2012.jpg", alt: "Open dag 2012" },
    ]
  },
  {
    jaar: "2011",
    fotos: [
      { src: "/afb/opendag-2011.jpg", alt: "Open dag 2011" },
      { src: "/afb/nieuw-dak.jpg", alt: "Nieuw dak op de schuur" },
    ]
  },
  {
    jaar: "2010",
    fotos: [
      { src: "/afb/opendag-2010.jpg", alt: "Open dag 2010" },
    ]
  },
];
---

<Layout title="Foto's" description="Fotogalerij van 't Leeuweriksveld — open dagen, oogstfeesten en het dagelijkse leven op de boerderij.">
  <div class="pagina-hero">
    <h1>Foto's</h1>
    <p>Open dagen, oogstfeesten en het leven op 't Leeuweriksveld</p>
  </div>

  <div class="broodkruimel">
    <div class="container">
      <a href="/">Home</a> &rsaquo; Foto's
    </div>
  </div>

  <!-- Sfeerfotos boven -->
  <div class="foto-wand foto-wand-3" style="max-height: 340px; overflow: hidden;">
    <img src="/afb/lw-floriaan-met-net-geoogste-lichtwortel.jpg" alt="Kathinka en Wouter in de boerenkool" style="height:340px; object-fit:cover;" />
    <img src="/afb/lw-blootgelegde-lichtwortels.jpg" alt="Het bedrijf van 't Leeuweriksveld" style="height:340px; object-fit:cover;" />
    <img src="/afb/lw-lichtwortel-schoon.jpg" alt="De kippenkar" style="height:340px; object-fit:cover;" />
  </div>

  <section class="sectie">
    <div class="container">

      {galerijen.map(galerie => (
        <div style="margin-bottom: 3rem;">
          <h2 style="margin-bottom: 1.25rem; border-bottom: 2px solid var(--groen-zacht); padding-bottom: 0.5rem;">
            {galerie.jaar === "2017" ? "Oogstfeest" : "Open dag"} {galerie.jaar}
          </h2>
          <div class={`foto-wand ${galerie.fotos.length === 1 ? "" : "foto-wand-3"}`}
               style={galerie.fotos.length === 1 ? "" : ""}>
            {galerie.fotos.map(foto => (
              <img src={foto.src} alt={foto.alt} style="height: 280px; object-fit: cover; border-radius: 4px;" />
            ))}
          </div>
        </div>
      ))}

      <!-- Vogels en natuur -->
      <div style="margin-bottom: 3rem;">
        <h2 style="margin-bottom: 1.25rem; border-bottom: 2px solid var(--groen-zacht); padding-bottom: 0.5rem;">Natuur op het bedrijf</h2>
        <div class="foto-wand foto-wand-3">
          <img src="/afb/kerkuil.jpg" alt="Kerkuil bij 't Leeuweriksveld" style="height: 280px; object-fit: cover; border-radius: 4px;" />
          <img src="/afb/leeuweriksveld_veld.png" alt="Overzicht van het veld" style="height: 280px; object-fit: cover; border-radius: 4px;" />
          <img src="/afb/lw-blootgelegde-lichtwortels.jpg" alt="Het land in seizoen" style="height: 280px; object-fit: cover; border-radius: 4px;" />
        </div>
      </div>

    </div>
  </section>
</Layout>
