---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Neem contact op met 't Leeuweriksveld in Emmen. Telefoon, e-mail, adres en openingstijden.">
  <div class="pagina-hero">
    <h1>Contact</h1>
    <p>We zijn te bereiken via telefoon, e-mail of bezoek aan de boerderijwinkel</p>
  </div>

  <div class="broodkruimel">
    <div class="container">
      <a href="/">Home</a> › Contact
    </div>
  </div>

  <section class="sectie">
    <div class="container">
      <div class="contact-grid">

        <div class="contact-kaart">
          <h3>📍 Adres</h3>
          <div class="gegeven">
            <span>Wouter en Kathinka Kamphuis<br />
            Zandzoom 72<br />
            7814 VJ Emmen</span>
          </div>
          <a href="/routebeschrijving" class="knop knop-groen" style="margin-top: 1rem; font-size: 0.9rem; padding: 0.5rem 1.2rem;">Routebeschrijving →</a>
        </div>

        <div class="contact-kaart">
          <h3>📞 Telefoon & e-mail</h3>
          <div class="gegeven">
            <span class="label">Telefoon:</span>
            <a href="tel:0591381445">0591-381445</a>
          </div>
          <div class="gegeven">
            <span class="label">E-mail:</span>
            <a href="mailto:info@leeuweriksveld.nl">info@leeuweriksveld.nl</a>
          </div>
          <p style="margin-top: 0.75rem; font-size: 0.9rem; color: var(--tekst-zacht);">Telefonisch bereikbaar maandag t/m vrijdag, 9:00–12:00.</p>
        </div>

        <div class="contact-kaart">
          <h3>🕒 Winkelopeningstijden</h3>
          <table class="tijden-tabel">
            <tr><td><strong>Maandag</strong></td><td>15:00–18:00</td></tr>
            <tr><td><strong>Donderdag</strong></td><td>14:00–18:00</td></tr>
            <tr><td><strong>Vrijdag</strong></td><td>9:00–17:00</td></tr>
            <tr><td><strong>Zaterdag</strong></td><td>9:00–14:00</td></tr>
            <tr><td>Di, Wo, Zo</td><td class="gesloten">Gesloten</td></tr>
          </table>
        </div>

        <div class="contact-kaart">
          <h3>ℹ️ Bedrijfsgegevens</h3>
          <div class="gegeven">
            <span class="label">KvK:</span>
            <span>04085776</span>
          </div>
          <div class="gegeven">
            <span class="label">Skal:</span>
            <span>025779</span>
          </div>
          <div class="gegeven">
            <span class="label">Certif.:</span>
            <span>Demeter · EU Biologisch</span>
          </div>
        </div>

      </div>

      <div class="inhoud-blok" style="margin-top: 2rem;">
        <h2>Rondleidingen</h2>
        <p>Bent u geïnteresseerd in een rondleiding over ons bedrijf? Bezoeken zijn welkom bij 't Leeuweriksveld — op afspraak en tegen een vergoeding. Neem contact op om een afspraak te maken.</p>
      </div>
    </div>
  </section>
</Layout>
